{
  "name": "mary-had-a-little-lamb",
  "description": "The canonical training dialogue for the paced-loop trainer and the table-driven stub KAgent. Single cascade, canon-first, atom reuse, subword canons grounded. This is the contract: the stub consumes it; the trainer's satisfaction logic must reproduce it; the real Kalvin must be reconciled to it. Authored in the design grill — see CONTEXT.md (Learned), specs/trainer-satisfaction.md, specs/stub-kagent.md.",
  "source": "(Mary had a little lamb)\nMHALL == SVO =>\n   S(ubject) = M\n   V(erb) = H\n   O(bject) = ALL =>\n     A > D(et)\n     L > M(od)\n     L > O\n",
  "_resolution_notes": "Klines are referenced by symbolic role, NOT by raw uint64 signature/node values, so the artifact survives tokenizer retraining. To resolve a role to a KValue: (1) compile `source` with compile_source(dev=True); (2) match each compiled entry by its `op` and its operand-role signatures (recursively), per the legend's structural descriptors. Word-position atoms L1/L2 (both the source character 'L') are distinguished by their word-binding position in '(Mary had a little lamb)' — L1=little (4th word), L2=lamb (5th word). Subword atoms (sw_*) are the BPE constituents of their parent word canon, matched positionally to the canon's nodes. Derived signatures MHALL/SVO/ALL are the OR-reduction of their canon operands.",
  "_band_legend": {
    "S1": "COUNTERSIGNED — the primary countersign pair",
    "S2": "Canon — signature == OR-reduction of nodes (authored semantic canons AND tokenizer subword canons)",
    "S3": "non-canonical relation — CONNOTED (>) or UNDERSIGNED (=)",
    "S4": "Identity — atom, empty nodes"
  },
  "legend": {
    "M":       {"op": "IDENTITY", "word": "Mary", "note": "word atom"},
    "H":       {"op": "IDENTITY", "word": "had"},
    "A":       {"op": "IDENTITY", "word": "a"},
    "L1":      {"op": "IDENTITY", "word": "little", "note": "4th word, first L"},
    "L2":      {"op": "IDENTITY", "word": "lamb", "note": "5th word, second L"},
    "S":       {"op": "IDENTITY", "word": "Subject", "note": "role atom"},
    "V":       {"op": "IDENTITY", "word": "Verb"},
    "O":       {"op": "IDENTITY", "word": "Object"},
    "D":       {"op": "IDENTITY", "word": "Det"},
    "Mo":      {"op": "IDENTITY", "word": "Mod"},

    "sw_Mary_1": {"op": "IDENTITY", "note": "BPE constituent 1 of Mary"},
    "sw_Mary_2": {"op": "IDENTITY", "note": "BPE constituent 2 of Mary"},
    "sw_had_1":  {"op": "IDENTITY", "note": "BPE constituent 1 of had"},
    "sw_had_2":  {"op": "IDENTITY", "note": "BPE constituent 2 of had"},
    "sw_L1_1":   {"op": "IDENTITY", "note": "BPE constituent 1 of little"},
    "sw_L1_2":   {"op": "IDENTITY", "note": "BPE constituent 2 of little"},
    "sw_L2_1":   {"op": "IDENTITY", "note": "BPE constituent 1 of lamb"},
    "sw_L2_2":   {"op": "IDENTITY", "note": "BPE constituent 2 of lamb"},

    "subword_Mary": {"op": "CANON", "signature_role": "M",  "operands": ["sw_Mary_1", "sw_Mary_2"]},
    "subword_had":  {"op": "CANON", "signature_role": "H",  "operands": ["sw_had_1", "sw_had_2"]},
    "subword_L1":   {"op": "CANON", "signature_role": "L1", "operands": ["sw_L1_1", "sw_L1_2"]},
    "subword_L2":   {"op": "CANON", "signature_role": "L2", "operands": ["sw_L2_1", "sw_L2_2"]},

    "MHALL":     {"op": "DERIVED_SIG", "operands": ["M", "H", "A", "L1", "L2"], "note": "OR-reduction"},
    "SVO":       {"op": "DERIVED_SIG", "operands": ["S", "V", "O"], "note": "OR-reduction"},
    "ALL":       {"op": "DERIVED_SIG", "operands": ["A", "L1", "L2"], "note": "OR-reduction"},

    "canon_MHALL": {"op": "CANON", "signature_role": "MHALL", "operands": ["M", "H", "A", "L1", "L2"]},
    "canon_SVO":   {"op": "CANON", "signature_role": "SVO",   "operands": ["S", "V", "O"]},
    "canon_ALL":   {"op": "CANON", "signature_role": "ALL",   "operands": ["A", "L1", "L2"]},

    "primary":       {"op": "COUNTERSIGNED", "signature_role": "MHALL", "operands": ["SVO"], "declared": "S1"},
    "primary_recip": {"op": "COUNTERSIGNED", "signature_role": "SVO",   "operands": ["MHALL"], "declared": "S1"},

    "rel_MS":    {"op": "UNDERSIGNED", "signature_role": "M",  "operands": ["S"],  "declared": "S3"},
    "rel_HV":    {"op": "UNDERSIGNED", "signature_role": "H",  "operands": ["V"],  "declared": "S3"},
    "rel_ALL_O": {"op": "UNDERSIGNED", "signature_role": "ALL","operands": ["O"],  "declared": "S3"},
    "rel_AD":    {"op": "CONNOTED",    "signature_role": "A",  "operands": ["D"],  "declared": "S3"},
    "rel_L1_Mo": {"op": "CONNOTED",    "signature_role": "L1", "operands": ["Mo"], "declared": "S3"},
    "rel_L2_O":  {"op": "CONNOTED",    "signature_role": "L2", "operands": ["O"],  "declared": "S3"}
  },
